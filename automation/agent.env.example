# Copy to automation/agent.env and edit. Do NOT commit agent.env.
# Required:
REPO=BitRefinery/trinohub

# Optional (defaults shown):
# WORKDIR=$HOME/.trinohub-agent/checkout
# LOGDIR=$HOME/.trinohub-agent/logs
# BASE_BRANCH=main
# MAX_ISSUES=3
# CLAUDE_MODEL=claude-opus-4-8
# TEST_CMD=.venv/bin/python -m unittest discover -s tests -v && .venv/bin/python testing/run_e2e.py

# If you authenticate Claude Code with an API key instead of `claude login`:
# ANTHROPIC_API_KEY=sk-ant-...
