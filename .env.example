# TrinoHub environment template.
#
# Copy to `.env` in the project root and fill in the values you need. The
# control plane loads `.env` automatically on start (see load_dotenv_once);
# values already set in the real environment win over the file.
#
# `.env` is git-ignored — never commit real keys.

# --- Ask Trino (natural-language SQL assistant) ------------------------------
# Ask Trino is disabled until an API key is set here. By default it talks to
# OpenRouter (https://openrouter.ai) — create a key there and paste it below.
# `ASK_TRINO_API_KEY` is an accepted alias for the same value.
OPENROUTER_API_KEY=

# Optional: model Ask Trino uses to write SQL. Default: openai/gpt-4o-mini.
# Any model id from openrouter.ai/models works (e.g. anthropic/claude-sonnet-4.5).
# Can also be set in the UI under Settings -> Ask Trino.
# ASK_TRINO_MODEL=

# Optional: point at a different OpenAI-compatible chat-completions endpoint.
# Default: https://openrouter.ai/api/v1/chat/completions
# ASK_TRINO_API_BASE=
